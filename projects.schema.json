{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Projects",
  "type": "object",
  "required": [
    "data"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string"
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": [
        "name",
        "description",
        "institution",
        "source",
        "id",
        "lead",
        "dimension",
        "co2e",
        "base",
        "cost",
        "eur",
        "status"
      ],
      "properties": {
        "last_updated": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "building": {
          "type": "string"
        },
        "lead": {
          "type": "string"
        },
        "dimension": {
          "type": "string"
        },
        "base": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "eur": {
          "type": "number"
        },
        "co2e": {
          "type": "number"
        },
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "image": {
          "type": "string",
          "format": "uri"
        },
        "institution": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "current",
            "completed",
            "unknown",
            "ongoing",
            "concept",
            "finalized"
          ]
        },
        "kpi": {
          "type": "object",
          "properties": {
            "carbon": {
              "type": "number"
            },
            "cost": {
              "type": "number"
            },
            "sdg": {
              "type": "number"
            },
            "lockin": {
              "type": "number"
            },
            "data": {
              "type": "number"
            }
          },
          "required": [
            "carbon",
            "cost",
            "sdg",
            "lockin",
            "data"
          ],
          "additionalProperties": false
        },
        "synenergies": {
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "minItems": 2,
            "maxItems": 2,
            "items": false
          }
        },
        "ai": {
          "type": "string"
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}